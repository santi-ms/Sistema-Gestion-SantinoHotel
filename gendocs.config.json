{
  "version": 1,
  "output": {
    "dir": "docs",
    "style": "detailed"
  },
  "include": [
    "src/**",
    "app/**",
    "lib/**"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**"
  ],
  "language": "es",
  "pr": {
    "strategy": "rolling",
    "branchName": "gendocs/auto-update",
    "targetBranch": "main"
  },
  "model": {
    "provider": "anthropic",
    "name": "claude-sonnet-4-6"
  }
}
