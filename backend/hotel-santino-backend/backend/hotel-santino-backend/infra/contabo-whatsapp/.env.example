# IP del servidor Contabo (sin http:// ni puerto)
# Ejemplo: 123.45.67.89
SERVER_IP=tu_ip_del_servidor_aqui

# URL del backend en Railway
# Ejemplo: https://hotel-santino-backend-production.up.railway.app
BOT_BACKEND_URL=https://hotel-santino-backend-production.up.railway.app

# Credenciales para n8n Basic Auth
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiar_password_seguro

# Evolution API Key (cambiar por una clave segura)
EVOLUTION_API_KEY=change-me-to-secure-key

# Credenciales de PostgreSQL para Evolution API
POSTGRES_USER=evolution
POSTGRES_PASSWORD=evolution123
POSTGRES_DBNAME=evolution
